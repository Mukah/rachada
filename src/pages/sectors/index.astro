---
import { getCollection } from 'astro:content'
import { getPageRoute } from '../../utils/page-routes'
import BaseLayout from '../../layouts/BaseLayout.astro'

const sectors = await getCollection('sectors')
---
<BaseLayout pageTitle="Setores">
	<h2>Setores</h2>
	<ul>
		{sectors.map((sector: any) => (
			<li>
				<a href={getPageRoute('sector', sector.id)}>{sector.data.name}</a>
			</li>
		))}
	</ul>

	<a href="https://github.com/mukah/rachada/new/main/data/sectors/setor/?filename=sector.json&value=CONTEUDO_AQUI">Adicionar novo</a>
</BaseLayout>
