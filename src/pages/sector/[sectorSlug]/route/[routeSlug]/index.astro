---
import BaseLayout from '../../../../../../src/layouts/BaseLayout.astro'
import sectors from '../../../../../../data/sectors.json'

export function getStaticPaths() {
	return sectors.flatMap((sector: any) =>
		sector.routes.map((route: any) => ({
			params: { sectorSlug: sector.slug, routeSlug: route.slug }
		}))
	);
}

const {
    sectorSlug,
    routeSlug
} = Astro.params as {
    sectorSlug: string;
    routeSlug: string
}

const sector = sectors.find((s: any) => s.slug === sectorSlug)
const route = sector?.routes.find((r: any) => r.slug === routeSlug)
---
<BaseLayout pageTitle="Rota">
	{route && (
		<div>
			<h1>{route.name}</h1>
			<p>Detalhes da rota {route.name} no setor {sector?.name}.</p>
		</div>
	)}

	<h3>Betas</h3>
</BaseLayout>
